generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  Admin
  Mahasiswa
  Dosen
}

enum jenis_kelamin {
  L
  P
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      Role     @default(Mahasiswa)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  Mahasiswa Mahasiswa?
  Dosen     Dosen?
}

model Dosen {
  nidn          Int           @id 
  nama_dosen    String
  jenis_kelamin jenis_kelamin
  alamat        String
  id_user       Int?          @unique
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  User       User?        @relation(fields: [id_user], references: [id])
  Matakuliah Matakuliah[]
  Jadwal     Jadwal[]
}

model Matakuliah {
  id_matakuliah   Int    @id
  nama_matakuliah String
  sks             Int
  id_dosen        Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  Dosen  Dosen    @relation(fields: [id_dosen], references: [nidn])
  Jadwal Jadwal[]
  KRS    KRS[]
}

model Mahasiswa {
  id             Int           @id @default(autoincrement())
  nim            String        @unique
  nama_mahasiswa String
  jenis_kelamin  jenis_kelamin
  jurusan        String
  userId         Int           @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  User User? @relation(fields: [userId], references: [id])
  KRS  KRS[]
}

model Jadwal {
  id            Int         @id @default(autoincrement())
  id_dosen      Int
  id_matakuliah Int
  jam_mulai     DateTime
  jam_selesai   DateTime
  hari          String
  dosen         Dosen?      @relation(fields: [id_dosen], references: [nidn])

  matakuliah    Matakuliah? @relation(fields: [id_matakuliah], references: [id_matakuliah])

  krs KRS[]
}

model KRS {
  id             Int    @id @default(autoincrement())
  id_mahasiswa   Int
  id_matakuliah  Int
  id_penjadwalan Int
  semester       Int
  tahun_ajaran   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  Jadwal    Jadwal    @relation(fields: [id_penjadwalan], references: [id])
  Mahasiswa Mahasiswa @relation(fields: [id_mahasiswa], references: [id])

  matakuliah Matakuliah? @relation(fields: [id_matakuliah], references: [id_matakuliah])
}
